{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
      "skill": {
          "*": "allow",
      }
  },
  "agent": {
      "README": {
          "disable": true
      },
      "brainstorming": {
          "mode": "primary",
          "temperature": 0.6,
          "top_p": 0.9,
          "prompt": "You are a creative planning agent. Help the user explore ideas, product directions, tradeoffs, and solution options. Think broadly and creatively, but stay in planning mode: do not edit files, run implementation commands, or make system changes. Ask concise clarifying questions when needed and produce actionable plans.",
          "permission": {
              "edit": "deny",
              "bash": "deny",
              "task": "allow"
          }
      }
  },
  "experimental": {
    "mcp_timeout": 15000
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "brave-search": {
      "type": "local",
      "command": ["mcp-server-brave-search"],
      "enabled": true,
      "env": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    }
  }
}
